// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ✅ NEW: User model to store user details from Supabase Auth
model User {
  id        String   @id // Supabase User ID
  email     String   @unique
  name      String?
  phone     String?
  avatar    String?
  joinedDate DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  addresses Address[]
  wishlists Wishlist[]
  orders    Order[]

  @@index([email])
  @@index([joinedDate])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  image     String?
  products  Product[]
  
  // ✅ Hierarchy
  parentId      String?
  parent        Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children      Category[] @relation("CategoryToCategory")

  // ✅ NEW: Strict Separation - Link to Featured Group
  featuredGroupId String?
  featuredGroup   FeaturedGroup? @relation(fields: [featuredGroupId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
  @@index([parentId])
  @@index([featuredGroupId])
}

model FeaturedGroup {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  image         String?
  order         Int       @default(0)
  categories    Category[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
  @@index([order])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  category      Category @relation(fields: [categoryId], references: [id])
  categoryId    String
  subCategory   String
  price         Float
  originalPrice Float
  discount      Int      @default(0)
  stock         Int      @default(0) // Stock quantity - 0 means out of stock
  sizes         String[] // Supported in PostgreSQL
  colors        String[] 
  image         String
  images        String[] 
  description   String   @default("")
  features      String[] @default([])
  variantPricing Json?    // Per-variant pricing: {"8GB | 128GB": {"price": 49999, "originalPrice": 59999}}
  isNew         Boolean  @default(false)
  isBestSeller  Boolean  @default(false)
  wishlists     Wishlist[]
  orderItems    OrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ✅ Performance Indexes
  @@index([categoryId])      // For filtering by category
  @@index([isNew])          // For "New Arrivals" section
  @@index([isBestSeller])   // For "Best Sellers" section
  @@index([slug])           // PHASE 1: Product detail page queries (/product/[slug])
  @@index([createdAt])      // PHASE 1: Sorting by creation date (new arrivals)
  @@index([name])           // PHASE 2 FIX: Index for search queries on product name
  @@index([stock])          // For filtering products with stock
}

model Banner {
  id          String   @id @default(cuid())
  type        String   // HERO, PROMO, etc.
  title       String
  subtitle    String?
  image       String
  buttonText  String?  @default("Shop Now")
  link        String?  @default("/")
  order       Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  street    String
  city      String
  state     String
  zipCode   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderNumber   String      @unique
  
  // Customer Info
  customerName  String
  customerEmail String
  customerPhone String
  
  // Delivery Address
  street        String
  city          String
  state         String
  zipCode       String
  
  // Order Details
  items         OrderItem[]
  subtotal      Float
  tax           Float       @default(0)
  shipping      Float       @default(0)
  total         Float
  
  // Status & Payment
  status        String      @default("pending") // pending, confirmed, shipped, delivered, cancelled
  paymentMethod String      @default("cod") // cod = Cash on Delivery
  paymentStatus String      @default("pending") // pending, completed
  
  // Timestamps
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([userId])
  @@index([orderNumber])
  @@index([status])                    // For filtering orders by status
  @@index([userId, createdAt])         // For user's order history with sorting
  @@index([status, createdAt])         // For dashboard status breakdown queries
  @@index([createdAt])                 // For time-based filtering
  @@index([customerEmail, createdAt])  // For newCustomersCount DISTINCT query on dashboard
}

model OrderItem {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  
  quantity  Int
  price     Float    // Price at time of purchase
  size      String?
  color     String?
  
  @@index([orderId])
  @@index([productId])
  @@index([productId, orderId])  // ✅ PHASE 6: Composite for grouping top products
}

// ✅ NEW: SiteSetting model for global configurations
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., 'show_featured_categories'
  value     String   // Dynamic value stored as string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
