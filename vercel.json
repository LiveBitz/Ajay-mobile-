{
  "buildCommand": "npm run build",
  "devCommand": "next dev -p $PORT",
  "installCommand": "npm ci",
  "functions": {
    "app/**": {
      "maxDuration": 60
    }
  },
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": {
      "required": false
    },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": {
      "required": false
    },
    "DATABASE_URL": {
      "required": false
    }
  }
}
